<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>TasteBites | Fresh Food Recipes</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 (free icons) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fefaf5;
            color: #2d2a24;
            line-height: 1.5;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Header / Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #e07a5f, #e09d32);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links a {
            text-decoration: none;
            font-weight: 500;
            color: #3a2e28;
            transition: color 0.2s;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: #e07a5f;
        }

        .btn-outline {
            border: 1.5px solid #e07a5f;
            background: transparent;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            color: #e07a5f;
            transition: 0.2s;
            cursor: pointer;
        }

        .btn-outline:hover {
            background: #e07a5f;
            color: white;
        }

        /* Hero */
        .hero {
            text-align: center;
            padding: 60px 0 48px;
        }

        .hero h1 {
            font-size: 48px;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 20px;
            color: #3b2c24;
        }

        .hero h1 span {
            color: #e07a5f;
        }

        .hero p {
            font-size: 18px;
            color: #5e4b3a;
            max-width: 600px;
            margin: 0 auto 32px;
        }

        .search-box {
            display: flex;
            max-width: 550px;
            margin: 0 auto;
            background: white;
            border-radius: 60px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            border: 1px solid #ffe3d6;
            overflow: hidden;
        }

        .search-box input {
            flex: 1;
            padding: 16px 24px;
            border: none;
            font-size: 16px;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .search-box button {
            background: #e07a5f;
            border: none;
            padding: 0 28px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            font-size: 16px;
        }

        .search-box button:hover {
            background: #c05e41;
        }

        /* Section title */
        .section-title {
            font-size: 32px;
            font-weight: 700;
            margin: 48px 0 24px 0;
            border-left: 5px solid #e07a5f;
            padding-left: 20px;
        }

        /* Recipe grid */
        .recipes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 32px;
            margin-bottom: 60px;
        }

        .recipe-card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 12px 24px rgba(0,0,0,0.04);
            transition: transform 0.25s ease, box-shadow 0.25s;
            cursor: pointer;
        }

        .recipe-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 30px rgba(0,0,0,0.08);
        }

        .card-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: #f2e2d4;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #bc8f6e;
        }

        .card-content {
            padding: 20px 20px 24px;
        }

        .card-category {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            color: #e07a5f;
            margin-bottom: 8px;
        }

        .card-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .card-meta {
            display: flex;
            gap: 16px;
            color: #7f6b5a;
            font-size: 14px;
            margin-bottom: 16px;
        }

        .card-meta i {
            margin-right: 6px;
            color: #e09d32;
        }

        .rating {
            color: #f4b942;
            letter-spacing: 2px;
            font-size: 14px;
        }

        /* Newsletter */
        .newsletter {
            background: #2d2a24;
            color: #fef6e8;
            border-radius: 48px;
            padding: 48px 32px;
            text-align: center;
            margin: 40px 0 60px;
        }

        .newsletter h3 {
            font-size: 28px;
            margin-bottom: 12px;
        }

        .newsletter p {
            max-width: 500px;
            margin: 0 auto 24px;
            opacity: 0.8;
        }

        .news-group {
            display: flex;
            max-width: 450px;
            margin: 0 auto;
            gap: 12px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .news-group input {
            flex: 1;
            padding: 14px 20px;
            border-radius: 60px;
            border: none;
            outline: none;
            font-family: 'Inter', sans-serif;
        }

        .news-group button {
            background: #e07a5f;
            border: none;
            padding: 0 28px;
            border-radius: 60px;
            font-weight: 600;
            color: white;
            cursor: pointer;
        }

        /* Footer */
        footer {
            border-top: 1px solid #efdfd3;
            padding: 40px 0 32px;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 24px;
            color: #6b5a4b;
        }

        .social i {
            font-size: 22px;
            margin-left: 20px;
            color: #9b7b64;
            transition: color 0.2s;
            cursor: pointer;
        }

        .social i:hover {
            color: #e07a5f;
        }

        @media (max-width: 700px) {
            .hero h1 {
                font-size: 36px;
            }
            .navbar {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <!-- Navigation -->
    <div class="navbar">
        <div class="logo">🍲 TasteBites</div>
        <div class="nav-links">
            <a href="#" class="active">Home</a>
            <a href="#">Recipes</a>
            <a href="#">Meal Ideas</a>
            <a href="#">Categories</a>
            <button class="btn-outline" id="submitRecipeBtn">+ Submit Recipe</button>
        </div>
    </div>

    <!-- Hero -->
    <div class="hero">
        <h1>Fresh flavors, <span>simple steps</span></h1>
        <p>Explore thousands of mouthwatering recipes created by home cooks and chefs.</p>
        <div class="search-box">
            <input type="text" id="searchInput" placeholder="Search by dish, ingredient, or cuisine...">
            <button id="searchBtn"><i class="fas fa-search"></i> Find</button>
        </div>
    </div>

    <!-- Featured recipes section -->
    <div class="section-title">
        🔥 Featured this week
    </div>
    <div class="recipes-grid" id="recipesGrid">
        <!-- dynamic cards will appear here from JS -->
    </div>

    <!-- Newsletter signup -->
    <div class="newsletter">
        <h3>📧 Get fresh recipes weekly</h3>
        <p>Subscribe for new meals, cooking tips & exclusive content.</p>
        <div class="news-group">
            <input type="email" placeholder="Your email address" id="newsEmail">
            <button id="subscribeBtn">Subscribe</button>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div>© 2025 TasteBites — cook with love</div>
        <div class="social">
            <i class="fab fa-instagram"></i>
            <i class="fab fa-pinterest"></i>
            <i class="fab fa-youtube"></i>
        </div>
    </footer>
</div>

<script>
    // Sample recipe dataset
    const recipes = [
        {
            id: 1,
            title: "Creamy Garlic Mushroom Pasta",
            category: "Vegetarian",
            time: "25 min",
            difficulty: "Easy",
            rating: 4.8,
            imageIcon: "🍝"
        },
        {
            id: 2,
            title: "Spicy Miso Ramen Bowl",
            category: "Asian Fusion",
            time: "40 min",
            difficulty: "Medium",
            rating: 4.9,
            imageIcon: "🍜"
        },
        {
            id: 3,
            title: "Mediterranean Chicken Bowl",
            category: "High Protein",
            time: "30 min",
            difficulty: "Easy",
            rating: 4.7,
            imageIcon: "🥗"
        },
        {
            id: 4,
            title: "Classic Tiramisu",
            category: "Dessert",
            time: "1h 15min",
            difficulty: "Medium",
            rating: 4.9,
            imageIcon: "🍰"
        },
        {
            id: 5,
            title: "Vegan Buddha Bowl",
            category: "Vegan",
            time: "20 min",
            difficulty: "Easy",
            rating: 4.6,
            imageIcon: "🥙"
        },
        {
            id: 6,
            title: "Smoky BBQ Pulled Jackfruit",
            category: "Vegan",
            time: "35 min",
            difficulty: "Medium",
            rating: 4.8,
            imageIcon: "🌮"
        }
    ];

    function renderRecipes(filterText = "") {
        const grid = document.getElementById("recipesGrid");
        if (!grid) return;

        let filtered = [...recipes];
        if (filterText.trim() !== "") {
            const lowerFilter = filterText.toLowerCase();
            filtered = recipes.filter(recipe => 
                recipe.title.toLowerCase().includes(lowerFilter) || 
                recipe.category.toLowerCase().includes(lowerFilter)
            );
        }

        if (filtered.length === 0) {
            grid.innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:40px;">🍽️ No recipes found. Try something else!</div>`;
            return;
        }

        grid.innerHTML = filtered.map(recipe => `
            <div class="recipe-card" data-id="${recipe.id}">
                <div class="card-img">
                    ${recipe.imageIcon}
                </div>
                <div class="card-content">
                    <div class="card-category">${recipe.category}</div>
                    <div class="card-title">${recipe.title}</div>
                    <div class="card-meta">
                        <span><i class="far fa-clock"></i> ${recipe.time}</span>
                        <span><i class="fas fa-chart-simple"></i> ${recipe.difficulty}</span>
                    </div>
                    <div class="rating">
                        ${'★'.repeat(Math.floor(recipe.rating))}${recipe.rating % 1 !== 0 ? '½' : ''} 
                        <span style="color:#aaa; font-size:13px;">(${recipe.rating})</span>
                    </div>
                </div>
            </div>
        `).join('');

        // attach click event to each card for "view recipe" demo
        document.querySelectorAll('.recipe-card').forEach(card => {
            card.addEventListener('click', (e) => {
                const id = card.getAttribute('data-id');
                const recipe = recipes.find(r => r.id == id);
                if (recipe) {
                    alert(`✨ "${recipe.title}" \n⏱️ ${recipe.time} · 🧑‍🍳 ${recipe.difficulty}\nFull recipe will open soon!`);
                } else {
                    alert("Recipe details coming soon!");
                }
            });
        });
    }

    // search functionality
    const searchInput = document.getElementById("searchInput");
    const searchBtn = document.getElementById("searchBtn");

    function performSearch() {
        const query = searchInput ? searchInput.value : "";
        renderRecipes(query);
    }

    if (searchBtn) {
        searchBtn.addEventListener("click", performSearch);
    }
    if (searchInput) {
        searchInput.addEventListener("keyup", (e) => {
            if (e.key === "Enter") performSearch();
        });
    }

    // Submit recipe demo
    const submitBtn = document.getElementById("submitRecipeBtn");
    if (submitBtn) {
        submitBtn.addEventListener("click", () => {
            alert("📝 Submit your own recipe — feature coming soon! Join our waitlist?");
        });
    }

    // Newsletter subscribe demo
    const subscribeBtn = document.getElementById("subscribeBtn");
    const newsEmail = document.getElementById("newsEmail");
    if (subscribeBtn) {
        subscribeBtn.addEventListener("click", () => {
            const email = newsEmail.value.trim();
            if (email && email.includes("@") && email.includes(".")) {
                alert(`🎉 Thanks for subscribing! Recipes will be sent to ${email}`);
                newsEmail.value = "";
            } else {
                alert("Please enter a valid email address.");
            }
        });
    }

    // initial render
    renderRecipes();
</script>
</body>
</html>